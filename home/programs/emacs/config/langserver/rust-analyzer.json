{
  "name": "rust-analyzer",
  "languageId": "rust",
  "command": ["rust-analyzer"],
  "settings": {},
  "projectFiles": ["Cargo.toml"],
  "capabilities": {
    "textDocument": {
      "hover": {
        "contentFormat": ["markdown"]
      }
    }
  },
  "initializationOptions": {
    "cachePriming": {
      "enable": false
    },
    "cargo": {
      "features": "all"
    },
    "completion": {
      "postfix": {
        "enable": false
      }
    }
  }
}
